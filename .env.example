# Copie para .env ou configure no painel do host (ex.: Vercel → Environment Variables).
# Nunca commite .env com valores reais.

# --- Frontend (Vite) — obrigatório em produção ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Beta limitado: oculta/bloqueia WhatsApp, newsletter, campanhas, inbox, automações, carrinho abandonado.
# Para receber usuários reais neste escopo, use true em produção.
# Ver: src/lib/beta-scope.ts
VITE_BETA_LIMITED_SCOPE=true

# Opcional: eventos sem PII do wizard /diagnostico → window.dataLayer (ex. GTM)
# VITE_ENABLE_DIAGNOSTICO_ANALYTICS=true

# Opcional: número WhatsApp de suporte (apenas dígitos, ex. 5511999998888) — Billing e CTAs.
# VITE_SUPPORT_WHATSAPP_E164=

# Opcional: MFA step-up (página /security/step-up) usa Clerk — só defina se essa rota for usada.
# VITE_CLERK_PUBLISHABLE_KEY=

# --- WhatsApp Meta Cloud (secrets no Supabase Edge, não aqui) ---
# META_WHATSAPP_VERIFY_TOKEN — webhook challenge (Meta Developer)
# META_APP_SECRET — validação X-Hub-Signature-256 em meta-whatsapp-webhook
# Guia: docs/meta-whatsapp-cloud-setup.md
