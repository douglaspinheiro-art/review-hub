# Copie para .env ou configure no painel do host (ex.: Vercel → Environment Variables).
# Nunca commite .env com valores reais.

# --- Frontend (Vite) — obrigatório em produção ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Beta limitado: oculta/bloqueia WhatsApp, newsletter, campanhas, inbox, automações, carrinho abandonado.
# Para receber usuários reais neste escopo, use true em produção.
# Ver: src/lib/beta-scope.ts
VITE_BETA_LIMITED_SCOPE=true

# Opcional: MFA step-up (página /security/step-up) usa Clerk — só defina se essa rota for usada.
# VITE_CLERK_PUBLISHABLE_KEY=
